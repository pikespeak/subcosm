{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../dist/types/server",
    "tsBuildInfoFile": "../dist/types/server/tsconfig.tsbuildinfo",
    "customConditions": [],
    "types": ["node"],
    "exactOptionalPropertyTypes": false,
    "rootDir": "../src/server"
  },
  // The server SOURCE project: prod modules only. Test files are excluded here
  // and type-checked by the sibling tools/tsconfig.server-tests.json project
  // (mirrors the engine source/tests split).
  "include": ["../src/server/**/*"],
  "exclude": ["../src/server/**/*.test.ts"],
  "references": [
    {
      "path": "./tsconfig.shared.json"
    },
    {
      "path": "./tsconfig.engine.json"
    }
  ]
}
