{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],

    "outDir": "../dist/types/engine",

    "tsBuildInfoFile": "../dist/types/engine/tsconfig.tsbuildinfo",

    "rootDir": "../src/engine"
  },
  // The engine SOURCE project: pure modules only. Test files are excluded here
  // and type-checked by the sibling tools/tsconfig.engine-tests.json project
  // (which can reach the shared tests/fixtures.ts module outside this rootDir).
  "include": ["../src/engine/**/*"],
  "exclude": ["../src/engine/**/*.test.ts"]
}
